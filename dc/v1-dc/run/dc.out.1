proc proc_print_msg { args } {
        parse_proc_arguments -args $args options
        if { [info exists options(-E)] } {
                echo "ERROR: $options(-E)"
        } elseif { [info exists options(-W)] } {
                echo "WARNING: $options(-W)"
        } elseif { [info exists options(-I)] } {
                echo "INFO: $options(-I)"
        }
}
