###################################################################

# Created by write_sdc on Sat Apr 18 10:54:54 2026

###################################################################
set sdc_version 1.8

set_units -time ns -resistance kOhm -capacitance pF -voltage V -current mA
set_ideal_network [get_ports io_aclk]
set_ideal_network [get_ports io_aresetn]
create_clock [get_ports io_aclk]  -name GCLK  -period 2  -waveform {0 1}
set_clock_uncertainty 0.2  [get_clocks GCLK]
set_clock_transition -min -fall 0.1 [get_clocks GCLK]
set_clock_transition -min -rise 0.1 [get_clocks GCLK]
set_clock_transition -max -fall 0.1 [get_clocks GCLK]
set_clock_transition -max -rise 0.1 [get_clocks GCLK]
group_path -weight 5  -name GCLK  -to [get_clocks GCLK]
group_path -name COMBO  -from [list [get_ports io_aresetn] [get_ports io_axi_slave_write_addr_valid]  \
